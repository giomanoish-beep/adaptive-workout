{
  "name": "adaptive-workout",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "catalog:generate": "npm run build --workspace @adaptive-workout/domain && node scripts/generate-exercise-catalog.mjs",
    "catalog:check": "npm run build --workspace @adaptive-workout/domain && node scripts/generate-exercise-catalog.mjs --check",
    "db:lint": "supabase db lint --local --level warning",
    "db:reset": "supabase db reset",
    "dev": "npm run dev --workspace @adaptive-workout/web",
    "edge-fn:build": "node scripts/build-edge-function.mjs generate-workout",
    "edge-fn:build:refresh": "node scripts/build-edge-function.mjs refresh-progression",
    "edge-fn:build:all": "node scripts/build-edge-function.mjs generate-workout && node scripts/build-edge-function.mjs refresh-progression",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "test": "vitest run",
    "test:e2e": "npm exec --workspace @adaptive-workout/web -- playwright test",
    "test:e2e-production-guard": "node scripts/test-e2e-production-guard.mjs",
    "test:e2e:headed": "npm run test:e2e:headed --workspace @adaptive-workout/web",
    "test:e2e:ui": "npm run test:e2e:ui --workspace @adaptive-workout/web",
    "test:e2e:debug": "npm run test:e2e:debug --workspace @adaptive-workout/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.12.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "supabase": "^2.109.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
